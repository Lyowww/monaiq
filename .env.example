# Used only by `docker compose` at the repository root (host port mapping, replica set name).
# Application secrets and API URLs live next to each app — see:
#   backend/.env.example
#   admin/.env.example
#   mobile/.env.example
#   translation-app/.env.example   (Go sidecar)
#   translation-app/web/.env.example (Translation UI → Nest API)
#   monaiq-landing/.env.example (if you use the landing app)
BACKEND_PORT=3000
MONGODB_PORT=27017
MONGODB_REPLICA_SET=rs0
