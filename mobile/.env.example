# Backend base URL including Nest global prefix `/api` (see backend configureApp setGlobalPrefix).
# Simulator / iOS: http://127.0.0.1:3001/api or http://localhost:3001/api
# Android emulator: http://10.0.2.2:3001/api
# Physical device: http://<your-lan-ip>:3001/api
EXPO_PUBLIC_API_URL=http://localhost:3001/api
